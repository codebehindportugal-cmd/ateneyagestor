APP_NAME="Backup Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Lisbon
APP_URL=https://gestao.example.com

APP_LOCALE=pt_PT
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_PT

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ASSUNCAO: ajustar para a base de dados real do teu VPS/Plesk.
# Para um teste rapido sem MySQL, podes usar sqlite (ver README).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backup_manager
DB_USERNAME=backup_manager
DB_PASSWORD=

# Drivers simples (ficheiro/sincrono) -- evita depender de Redis ou de
# tabelas extra de cache/jobs para este MVP. Podes mudar mais tarde se
# precisares de filas assincronas a serio.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="naoresponder@example.com"
MAIL_FROM_NAME="${APP_NAME}"
