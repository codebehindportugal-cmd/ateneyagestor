# Copy this to .env on the production server and fill in every value.
# Generate APP_KEY with: php artisan key:generate --show
# Never commit the real .env to git.

APP_NAME="Backup Manager"
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=Europe/Lisbon
APP_URL=https://backup.yourdomain.com

APP_LOCALE=pt_PT
APP_FALLBACK_LOCALE=en

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backup_manager
DB_USERNAME=backup_manager
DB_PASSWORD=                    # strong random password

# ── Sessions / Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=480
CACHE_STORE=file

# ── Queue ────────────────────────────────────────────────────────────────────
# Keep "sync" if you won't run a queue worker (scheduler tasks still run).
# Switch to "database" if you add queued jobs later.
QUEUE_CONNECTION=sync

# ── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=naoresponder@yourdomain.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="naoresponder@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
